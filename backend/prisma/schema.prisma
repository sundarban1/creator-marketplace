generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String
  role             Role
  isEmailVerified  Boolean           @default(false)
  isPhoneVerified  Boolean           @default(false)
  refreshToken     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  phone            String?           @unique
  isOnboarded      Boolean           @default(false)
  isActive         Boolean           @default(true)
  // Set only when an admin suspends this account (distinct from a user's own
  // self-deactivation, which also flips isActive false but leaves this null).
  // Login blocks outright when this is set; self-deactivated accounts still
  // auto-reactivate on next login.
  suspendedAt      DateTime?
  pushToken        String?
  deviceId         String?
  businessProfile  BusinessProfile?
  creatorProfile   CreatorProfile?
  issueReports     IssueReport[]
  sentMessages     Message[]         @relation("MessageSender")
  notifications    Notification[]
  otpVerifications OtpVerification[]
  supportRequests  SupportRequest[]

  @@map("users")
}

model CreatorProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  fullName           String?
  bio                String?
  location           String?
  avatarUrl          String?
  categories         String[]
  socialLinks        Json               @default("{}")
  portfolioLinks     Json               @default("[]")
  isVerified         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  username           String?            @unique
  paymentMethods     String[]           @default([])
  prefPlatforms      String[]           @default([])
  prefLocations      String[]           @default([])
  prefBudgetMin      Float              @default(0)
  prefBudgetMax      Float              @default(500)
  locationLat        Float?
  locationLng        Float?
  nearbyRadiusKm     Int                @default(25)
  nearbyUseHomeLocation Boolean         @default(false)
  referralCode       String?              @unique
  citizenshipDocUrl     String?
  citizenshipStatus     CitizenshipStatus  @default(NONE)
  citizenshipUploadedAt DateTime?
  applications         Application[]
  conversations        Conversation[]       @relation("CreatorConversations")
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteBusinesses   FavoriteBusiness[]
  socialAccounts       SocialAccount[]
  savedBy              SavedCreator[]
  receivedInvitations  CampaignInvitation[]
  referralsMade        Referral[]           @relation("ReferralsMade")
  referralsReceived    Referral?            @relation("ReferralsReceived")
  withdrawals          Withdrawal[]

  @@map("creator_profiles")
}

model Withdrawal {
  id        String   @id @default(cuid())
  creatorId String
  amount    Float
  method    String
  createdAt DateTime @default(now())

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@map("withdrawals")
}

model Referral {
  id           String         @id @default(cuid())
  referrerId   String
  referredId   String         @unique
  code         String
  status       ReferralStatus @default(PENDING)
  linkedAt     DateTime       @default(now())
  expiresAt    DateTime
  completedAt  DateTime?
  rewardAmount Decimal        @default(500)
  reviewedBy   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  referrer CreatorProfile @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred CreatorProfile @relation("ReferralsReceived", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referrals")
}

enum ReferralStatus {
  PENDING
  COMPLETED
  EXPIRED
}

model SocialAccount {
  id               String         @id @default(cuid())
  creatorProfileId String
  platform         String
  profileUrl       String
  followers        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, platform])
  @@map("social_accounts")
}

model BusinessProfile {
  id                  String               @id @default(cuid())
  userId              String               @unique
  businessName        String?
  description         String?
  logoUrl             String?
  website             String?
  categories          String[]
  panNo               String?
  location            String?
  phone               String?
  isVerified          Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  allowDirectMessages Boolean              @default(true)
  hideContactDetails  Boolean              @default(false)
  showPublicProfile   Boolean              @default(true)
  paymentMethods      String[]             @default([])
  referralCode        String?              @unique
  socialLinks              Json                 @default("{}")
  presenceServices         String[]             @default([])
  defaultPlatforms         String[]             @default([])
  defaultCreatorCategories String[]             @default([])
  defaultBudgetRange       String?
  panDocUrl               String?
  panDocStatus            DocumentStatus       @default(NONE)
  panDocUploadedAt        DateTime?
  companyRegDocUrl        String?
  companyRegDocStatus     DocumentStatus       @default(NONE)
  companyRegDocUploadedAt DateTime?
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns           Campaign[]
  conversations       Conversation[]       @relation("BusinessConversations")
  favoritedBy         FavoriteBusiness[]
  savedCreators       SavedCreator[]
  sentInvitations     CampaignInvitation[]
  referralsMade       BusinessReferral[]   @relation("BizReferralsMade")
  referralsReceived   BusinessReferral?    @relation("BizReferralsReceived")

  @@map("business_profiles")
}

model BusinessReferral {
  id           String         @id @default(cuid())
  referrerId   String
  referredId   String         @unique
  code         String
  status       ReferralStatus @default(PENDING)
  linkedAt     DateTime       @default(now())
  expiresAt    DateTime
  completedAt  DateTime?
  rewardAmount Decimal        @default(500)
  reviewedBy   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  referrer BusinessProfile @relation("BizReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred BusinessProfile @relation("BizReferralsReceived", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("business_referrals")
}

model Campaign {
  id             String          @id @default(cuid())
  businessId     String
  title          String
  description    String
  template       String?
  featureImageUrl String?
  category       String
  goals          Json            @default("[]")
  platform       String
  minFollowers   Int             @default(0)
  contentType    String
  deliverables   String
  deadline       DateTime
  location       String?
  locationLat    Float?
  locationLng    Float?
  budgetMin      Float
  budgetMax      Float
  paymentType    String
  status         CampaignStatus  @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isFeatured     Boolean         @default(false)
  creatorsNeeded Int             @default(1)
  campaignType  CampaignType @default(PAID_CAMPAIGN)
  capacity      Int?
  eventDate     DateTime?
  venue         String?
  benefits      Json         @default("[]")
  eventStatus   EventStatus  @default(OPEN)
  paymentStatus PaymentStatus @default(UNPAID)
  paidAt        DateTime?
  paymentMethod String?
  objective              String?
  contentGuidelines      String[]      @default([])
  targetAudience         String[]      @default([])
  hashtags               String[]      @default([])
  sampleCaption          String?
  callToAction           String?
  approvalRequirements   String?
  aiGenerated            Boolean       @default(false)
  aiPrompt               String?
  aiSuggestedCategories  String[]      @default([])
  aiSuggestedPlatforms   String[]      @default([])
  aiNeedsInputFields     String[]      @default([])
  applications   Application[]
  business       BusinessProfile    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  invitations    CampaignInvitation[]

  @@index([businessId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([campaignType, status])
  @@index([locationLat, locationLng])
  @@map("campaigns")
}

model Application {
  id            String            @id @default(cuid())
  campaignId    String
  creatorId     String
  coverLetter   String
  proposedRate  Float
  timeline      String
  socialHandles Json              @default("{}")
  portfolioUrl  String?
  status          ApplicationStatus @default(PENDING)
  workStatus      WorkStatus        @default(NONE)
  workNote        String?
  submittedAt     DateTime?
  deliverableUrls String?
  paymentStatus   PaymentStatus     @default(UNPAID)
  paidAt          DateTime?
  // Set only when an admin manually releases the held escrow payment —
  // brand approval no longer releases funds automatically, see approveWork().
  releasedAt         DateTime?
  releasedByAdminId  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  campaign        Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator       CreatorProfile    @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@index([creatorId])
  @@index([creatorId, createdAt(sort: Desc)])
  @@index([campaignId, status])
  @@map("applications")
}

model Conversation {
  id             String             @id @default(cuid())
  creatorId      String
  businessId     String
  campaignId     String?
  createdAt      DateTime           @default(now())
  status         ConversationStatus @default(PENDING)
  requestMessage String?
  lastMessageAt  DateTime?
  businessSeenAt DateTime?
  creatorSeenAt  DateTime?
  business       BusinessProfile    @relation("BusinessConversations", fields: [businessId], references: [id], onDelete: Cascade)
  campaign       Campaign?          @relation(fields: [campaignId], references: [id])
  creator        CreatorProfile     @relation("CreatorConversations", fields: [creatorId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([creatorId, businessId])
  @@index([businessId])
  @@index([lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

model LegalSection {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  icon      String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("legal_sections")
}

model FaqArticle {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_articles")
}

model SupportRequest {
  id        String   @id @default(cuid())
  userId    String?
  topic     String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])

  @@map("support_requests")
}

model IssueReport {
  id          String   @id @default(cuid())
  userId      String?
  type        String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])

  @@map("issue_reports")
}

model HelpArticle {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("help_articles")
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("otp_verifications")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  refId     String?
  refType   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@map("notifications")
}

model FavoriteBusiness {
  id         String          @id @default(cuid())
  creatorId  String
  businessId String
  createdAt  DateTime        @default(now())
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, businessId])
  @@map("favorite_businesses")
}

model SavedCreator {
  id         String          @id @default(cuid())
  businessId String
  creatorId  String
  createdAt  DateTime        @default(now())
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([businessId, creatorId])
  @@map("saved_creators")
}

model CampaignInvitation {
  id         String          @id @default(cuid())
  campaignId String
  creatorId  String
  businessId String
  message    String?
  createdAt  DateTime        @default(now())
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@map("campaign_invitations")
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

enum Role {
  CREATOR
  BUSINESS
  ADMIN
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  CANCELLED
}

enum ConversationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CampaignType {
  PAID_CAMPAIGN
  OPEN_EVENT
}

enum EventStatus {
  OPEN
  FULL
  CLOSED
}

enum WorkStatus {
  NONE
  IN_PROGRESS
  SUBMITTED
  APPROVED
}

enum PaymentStatus {
  UNPAID
  PAID
  RELEASED
  REFUNDED
}

enum CategoryScope {
  CREATOR
  BUSINESS
  BOTH
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum CitizenshipStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum DocumentStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

model Category {
  id        String         @id @default(cuid())
  icon      String
  iconBg    String
  color     String         @default("#6B7280")
  name      String
  key       String         @unique
  scope     CategoryScope  @default(BOTH)
  status    CategoryStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("categories")
}
