generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String
  role             Role
  isEmailVerified  Boolean           @default(false)
  isPhoneVerified  Boolean           @default(false)
  refreshToken     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  phone            String?           @unique
  isOnboarded      Boolean           @default(false)
  isActive         Boolean           @default(true)
  // Set only when an admin suspends this account (distinct from a user's own
  // self-deactivation, which also flips isActive false but leaves this null).
  // Login blocks outright when this is set; self-deactivated accounts still
  // auto-reactivate on next login.
  suspendedAt      DateTime?
  pushToken        String?
  deviceId         String?
  businessProfile  BusinessProfile?
  creatorProfile   CreatorProfile?
  issueReports     IssueReport[]
  sentMessages     Message[]         @relation("MessageSender")
  notifications    Notification[]
  otpVerifications OtpVerification[]
  supportRequests  SupportRequest[]
  reviewsGiven     Review[]          @relation("ReviewFrom")
  reviewsReceived  Review[]          @relation("ReviewTo")

  @@index([role])
  @@map("users")
}

model CreatorProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  fullName           String?
  bio                String?
  location           String?
  avatarUrl          String?
  categories         String[]
  socialLinks        Json               @default("{}")
  portfolioLinks     Json               @default("[]")
  isVerified         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  username           String?            @unique
  paymentMethods     String[]           @default([])
  prefPlatforms      String[]           @default([])
  prefLocations      String[]           @default([])
  prefBudgetMin      Float              @default(0)
  prefBudgetMax      Float              @default(500)
  locationLat        Float?
  locationLng        Float?
  nearbyRadiusKm     Int                @default(25)
  nearbyUseHomeLocation Boolean         @default(false)
  referralCode       String?              @unique
  citizenshipDocUrl     String?
  citizenshipStatus     CitizenshipStatus  @default(NONE)
  citizenshipUploadedAt DateTime?
  applications         Application[]
  conversations        Conversation[]       @relation("CreatorConversations")
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteBusinesses   FavoriteBusiness[]
  socialAccounts       SocialAccount[]
  savedBy              SavedCreator[]
  receivedInvitations  CampaignInvitation[]
  referralsMade        Referral[]           @relation("ReferralsMade")
  referralsReceived    Referral?            @relation("ReferralsReceived")
  withdrawals          Withdrawal[]
  profileViews         ProfileView[]

  @@index([isVerified])
  @@map("creator_profiles")
}

model Withdrawal {
  id        String   @id @default(cuid())
  creatorId String
  amount    Float
  method    String
  createdAt DateTime @default(now())

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@map("withdrawals")
}

model Referral {
  id           String         @id @default(cuid())
  referrerId   String
  referredId   String         @unique
  code         String
  status       ReferralStatus @default(PENDING)
  linkedAt     DateTime       @default(now())
  expiresAt    DateTime
  completedAt  DateTime?
  rewardAmount Decimal        @default(500)
  reviewedBy   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  referrer CreatorProfile @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred CreatorProfile @relation("ReferralsReceived", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referrals")
}

enum ReferralStatus {
  PENDING
  COMPLETED
  EXPIRED
}

model SocialAccount {
  id               String         @id @default(cuid())
  creatorProfileId String
  platform         String
  profileUrl       String
  followers        Int            @default(0)
  // True once profileUrl/followers were pulled directly from the platform's API via
  // OAuth (e.g. YouTube) rather than typed in by the creator.
  connectedViaOAuth Boolean       @default(false)
  // The platform's own user/channel id — lets a reconnect find and update the same
  // row instead of erroring on the creatorProfileId+platform unique constraint.
  platformUserId   String?
  avatarUrl        String?
  // Persisted so the follower/subscriber count can keep refreshing itself (manual
  // "Refresh" tap + the scheduled job in jobs/refreshSocialFollowers.ts) long after
  // the connect flow's own short-lived token would otherwise have expired.
  // Never exposed in any DTO — see creator.dto.ts's toSocialAccountDto allowlist.
  accessToken      String?
  refreshToken     String?
  tokenExpiresAt   DateTime?
  // Distinguishes HOW this row was connected when the platform alone is ambiguous —
  // 'instagram' can come from either the Facebook-Page-linked flow or Instagram's own
  // direct login, and each stores a token from a different API with a different
  // refresh mechanism (see creator.service.ts refreshAllSocialAccountFollowers).
  oauthConnectionType String?
  // Last time `followers` was actually re-fetched from the platform — distinct from
  // `updatedAt`, which also changes on unrelated edits (e.g. connectedViaOAuth flips).
  followersSyncedAt DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, platform])
  @@map("social_accounts")
}

// Tracks distinct brand views of a creator profile — capped to one row per
// business per creator per 24h at the service layer (see analytics.service.ts
// recordProfileView), not a DB constraint, since the window is time-based.
model ProfileView {
  id         String          @id @default(cuid())
  creatorId  String
  businessId String
  viewedAt   DateTime        @default(now())
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([creatorId, viewedAt])
  @@index([creatorId, businessId, viewedAt])
  @@map("profile_views")
}

model BusinessProfile {
  id                  String               @id @default(cuid())
  userId              String               @unique
  businessName        String?
  description         String?
  logoUrl             String?
  website             String?
  categories          String[]
  panNo               String?
  location            String?
  phone               String?
  isVerified          Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  allowDirectMessages Boolean              @default(true)
  hideContactDetails  Boolean              @default(false)
  showPublicProfile   Boolean              @default(true)
  paymentMethods      String[]             @default([])
  referralCode        String?              @unique
  socialLinks              Json                 @default("{}")
  presenceServices         String[]             @default([])
  defaultPlatforms         String[]             @default([])
  defaultCreatorCategories String[]             @default([])
  defaultBudgetRange       String?
  panDocUrl               String?
  panDocStatus            DocumentStatus       @default(NONE)
  panDocUploadedAt        DateTime?
  companyRegDocUrl        String?
  companyRegDocStatus     DocumentStatus       @default(NONE)
  companyRegDocUploadedAt DateTime?
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns           Campaign[]
  conversations       Conversation[]       @relation("BusinessConversations")
  favoritedBy         FavoriteBusiness[]
  savedCreators       SavedCreator[]
  sentInvitations     CampaignInvitation[]
  referralsMade       BusinessReferral[]   @relation("BizReferralsMade")
  referralsReceived   BusinessReferral?    @relation("BizReferralsReceived")
  profileViews        ProfileView[]

  @@index([isVerified])
  @@map("business_profiles")
}

model BusinessReferral {
  id           String         @id @default(cuid())
  referrerId   String
  referredId   String         @unique
  code         String
  status       ReferralStatus @default(PENDING)
  linkedAt     DateTime       @default(now())
  expiresAt    DateTime
  completedAt  DateTime?
  rewardAmount Decimal        @default(500)
  reviewedBy   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  referrer BusinessProfile @relation("BizReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred BusinessProfile @relation("BizReferralsReceived", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("business_referrals")
}

model Campaign {
  id             String          @id @default(cuid())
  businessId     String
  title          String
  description    String
  template       String?
  featureImageUrl String?
  category       String
  goals          Json            @default("[]")
  platforms      String[]        @default([])
  minFollowers   Int             @default(0)
  contentType    String
  deliverables   String
  deadline       DateTime
  location       String?
  locationLat    Float?
  locationLng    Float?
  budgetMin      Float
  budgetMax      Float
  paymentType    String
  status         CampaignStatus  @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  isFeatured     Boolean         @default(false)
  creatorsNeeded Int             @default(1)
  campaignType  CampaignType @default(PAID_CAMPAIGN)
  capacity      Int?
  eventDate     DateTime?
  venue         String?
  benefits      Json         @default("[]")
  eventStatus   EventStatus  @default(OPEN)
  paymentStatus PaymentStatus @default(UNPAID)
  paidAt        DateTime?
  paymentMethod String?
  objective              String?
  contentGuidelines      String[]      @default([])
  targetAudience         String[]      @default([])
  hashtags               String[]      @default([])
  sampleCaption          String?
  callToAction           String?
  approvalRequirements   String?
  aiGenerated            Boolean       @default(false)
  aiPrompt               String?
  aiSuggestedCategories  String[]      @default([])
  aiSuggestedPlatforms   String[]      @default([])
  aiNeedsInputFields     String[]      @default([])
  applications   Application[]
  business       BusinessProfile    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  invitations    CampaignInvitation[]

  @@index([businessId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([campaignType, status])
  @@index([locationLat, locationLng])
  @@map("campaigns")
}

model Application {
  id            String            @id @default(cuid())
  campaignId    String
  creatorId     String
  coverLetter   String
  proposedRate  Float
  timeline      String
  socialHandles Json              @default("{}")
  portfolioUrl  String?
  status          ApplicationStatus @default(PENDING)
  workStatus      WorkStatus        @default(NONE)
  workNote        String?
  submittedAt     DateTime?
  deliverableUrls String?
  paymentStatus   PaymentStatus     @default(UNPAID)
  paidAt          DateTime?
  // Set only when an admin manually releases the held escrow payment —
  // brand approval no longer releases funds automatically, see approveWork().
  releasedAt         DateTime?
  releasedByAdminId  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  campaign        Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator       CreatorProfile    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  reviews         Review[]

  @@unique([campaignId, creatorId])
  @@index([creatorId])
  @@index([creatorId, createdAt(sort: Desc)])
  @@index([campaignId, status])
  @@map("applications")
}

// One row per rater per completed application — a creator and a business can
// each leave one review of the other once work is fully COMPLETED (see
// completeProject() in campaign.service.ts, the terminal workStatus).
model Review {
  id            String      @id @default(cuid())
  applicationId String
  fromUserId    String
  toUserId      String
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromUser      User        @relation("ReviewFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser        User        @relation("ReviewTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([applicationId, fromUserId])
  @@index([toUserId])
  @@map("reviews")
}

model Conversation {
  id             String             @id @default(cuid())
  creatorId      String
  businessId     String
  campaignId     String?
  createdAt      DateTime           @default(now())
  status         ConversationStatus @default(PENDING)
  // True when ACCEPTED was set automatically by a proposal-accept (no real chat
  // request/accept happened) — such conversations revert to PENDING once the
  // project completes, rather than staying open indefinitely.
  autoAccepted   Boolean            @default(false)
  requestMessage String?
  lastMessageAt  DateTime?
  businessSeenAt DateTime?
  creatorSeenAt  DateTime?
  // "Delete conversation" is per-side only (like Messenger/Instagram) — hiding it
  // from one participant's inbox never affects the other's copy. Both flags reset
  // to false the moment a new message is sent, so the thread reappears for
  // whichever side had hidden it.
  hiddenForCreator  Boolean         @default(false)
  hiddenForBusiness Boolean         @default(false)
  business       BusinessProfile    @relation("BusinessConversations", fields: [businessId], references: [id], onDelete: Cascade)
  campaign       Campaign?          @relation(fields: [campaignId], references: [id])
  creator        CreatorProfile     @relation("CreatorConversations", fields: [creatorId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([creatorId, businessId])
  // Covers the inbox list query (messaging.repository.ts findConversationsByCreator/
  // findConversationsByBusiness): filter by side + hidden flag, ordered by
  // lastMessageAt. The old standalone @@index([businessId]) is superseded — a
  // composite index still serves businessId-only lookups via its leading column.
  @@index([creatorId, hiddenForCreator, lastMessageAt(sort: Desc)])
  @@index([businessId, hiddenForBusiness, lastMessageAt(sort: Desc)])
  @@index([lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType  @default(TEXT)
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime     @default(now())
  // "Delete for everyone" (sender-only, no time limit) — the row is kept so
  // history/pagination doesn't shift, but the content is tombstoned in the DTO.
  deletedAt         DateTime?
  deletedBy         String?
  // "Delete for me" — hides the message from one side's view without touching
  // the other participant's copy or the underlying content.
  hiddenForCreator  Boolean      @default(false)
  hiddenForBusiness Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

model LegalSection {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  icon      String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("legal_sections")
}

model FaqArticle {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_articles")
}

model SupportRequest {
  id        String   @id @default(cuid())
  userId    String?
  // Set only for anonymous submissions (e.g. the public landing-page contact
  // form) — logged-in submissions identify the sender via `user` instead.
  guestName  String?
  guestEmail String?
  topic     String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])

  @@map("support_requests")
}

model IssueReport {
  id          String   @id @default(cuid())
  userId      String?
  type        String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])

  @@map("issue_reports")
}

model HelpArticle {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("help_articles")
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("otp_verifications")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  refId     String?
  refType   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@map("notifications")
}

model FavoriteBusiness {
  id         String          @id @default(cuid())
  creatorId  String
  businessId String
  createdAt  DateTime        @default(now())
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, businessId])
  @@map("favorite_businesses")
}

model SavedCreator {
  id         String          @id @default(cuid())
  businessId String
  creatorId  String
  createdAt  DateTime        @default(now())
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([businessId, creatorId])
  @@map("saved_creators")
}

model CampaignInvitation {
  id         String          @id @default(cuid())
  campaignId String
  creatorId  String
  businessId String
  message    String?
  createdAt  DateTime        @default(now())
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@map("campaign_invitations")
}

// Aggregated, incrementally-updated stats — kept in sync by analytics.service.ts
// at the exact point each underlying event already happens elsewhere in the
// codebase, so the analytics dashboard never has to re-aggregate raw
// Application/Campaign/Withdrawal rows on every request. profileCompletion
// and referral stats are intentionally NOT stored here — they're cheap to
// compute live (see analytics.service.ts) and storing them risks drift.
model CreatorAnalytics {
  userId                String   @id
  totalProfileViews     Int      @default(0)
  totalEarnings         Float    @default(0)
  pendingEarnings       Float    @default(0)
  invitationsReceived   Int      @default(0)
  applicationsSubmitted Int      @default(0)
  applicationsAccepted  Int      @default(0)
  applicationsRejected  Int      @default(0)
  activeCampaigns       Int      @default(0)
  completedCampaigns    Int      @default(0)
  averageRating         Float    @default(0)
  reviewCount           Int      @default(0)
  responseTimeAvgMins   Float    @default(0)
  responseTimeSamples   Int      @default(0)
  updatedAt             DateTime @updatedAt

  @@map("creator_analytics")
}

model BrandAnalytics {
  userId              String   @id
  campaignsCreated    Int      @default(0)
  activeCampaigns     Int      @default(0)
  completedCampaigns  Int      @default(0)
  totalSpend          Float    @default(0)
  applicationsReceived Int     @default(0)
  creatorsHired       Int      @default(0)
  averageRatingGiven  Float    @default(0)
  ratingsGivenCount   Int      @default(0)
  responseTimeAvgMins Float    @default(0)
  responseTimeSamples Int      @default(0)
  updatedAt           DateTime @updatedAt

  @@map("brand_analytics")
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

enum Role {
  CREATOR
  BUSINESS
  ADMIN
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  CANCELLED
}

enum ConversationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CampaignType {
  PAID_CAMPAIGN
  OPEN_EVENT
}

enum EventStatus {
  OPEN
  FULL
  CLOSED
}

enum WorkStatus {
  NONE
  IN_PROGRESS
  SUBMITTED
  APPROVED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  RELEASED
  REFUNDED
}

enum CategoryScope {
  CREATOR
  BUSINESS
  BOTH
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum CitizenshipStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum DocumentStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

model Category {
  id        String         @id @default(cuid())
  icon      String
  iconBg    String
  color     String         @default("#6B7280")
  name      String
  key       String         @unique
  scope     CategoryScope  @default(BOTH)
  status    CategoryStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("categories")
}

enum PlatformStatus {
  ACTIVE
  INACTIVE
}

// Admin-managed source of truth for social platforms (Instagram, TikTok, etc.) —
// referenced by name/key everywhere a platform needs to be selected or displayed
// (campaign creation, creator preferred platforms, social account connections),
// instead of hardcoding the list in every client.
model Platform {
  id        String         @id @default(cuid())
  icon      String
  iconBg    String
  color     String         @default("#6B7280")
  name      String
  key       String         @unique
  status    PlatformStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("platforms")
}
