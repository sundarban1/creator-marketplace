generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String
  role             Role
  isEmailVerified  Boolean           @default(false)
  refreshToken     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  phone            String?           @unique
  isOnboarded      Boolean           @default(false)
  isActive         Boolean           @default(true)
  pushToken        String?
  businessProfile  BusinessProfile?
  creatorProfile   CreatorProfile?
  issueReports     IssueReport[]
  sentMessages     Message[]         @relation("MessageSender")
  notifications    Notification[]
  otpVerifications OtpVerification[]
  supportRequests  SupportRequest[]

  @@map("users")
}

model CreatorProfile {
  id                  String               @id @default(cuid())
  userId              String               @unique
  fullName            String?
  bio                 String?
  location            String?
  avatarUrl           String?
  categories          String[]
  socialLinks         Json                 @default("{}")
  portfolioLinks      Json                 @default("[]")
  isVerified          Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  username            String?              @unique
  paymentMethods      String[]             @default([])
  prefPlatforms       String[]             @default([])
  prefLocations       String[]             @default([])
  prefBudgetMin       Float                @default(0)
  prefBudgetMax       Float                @default(500)
  locationLat         Float?
  locationLng         Float?
  applications        Application[]
  conversations       Conversation[]       @relation("CreatorConversations")
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteBusinesses  FavoriteBusiness[]
  socialAccounts      SocialAccount[]
  savedBy             SavedCreator[]
  receivedInvitations CampaignInvitation[]

  @@map("creator_profiles")
}

model SocialAccount {
  id               String         @id @default(cuid())
  creatorProfileId String
  platform         String
  profileUrl       String
  followers        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  creatorProfile   CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, platform])
  @@map("social_accounts")
}

model BusinessProfile {
  id                  String               @id @default(cuid())
  userId              String               @unique
  businessName        String?
  description         String?
  logoUrl             String?
  website             String?
  categories          String[]
  panNo               String?
  location            String?
  isVerified          Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  allowDirectMessages Boolean              @default(true)
  hideContactDetails  Boolean              @default(false)
  showPublicProfile   Boolean              @default(true)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns           Campaign[]
  conversations       Conversation[]       @relation("BusinessConversations")
  favoritedBy         FavoriteBusiness[]
  savedCreators       SavedCreator[]
  sentInvitations     CampaignInvitation[]

  @@map("business_profiles")
}

model Campaign {
  id             String               @id @default(cuid())
  businessId     String
  title          String
  description    String
  template       String?
  category       String
  goals          Json                 @default("[]")
  platform       String
  minFollowers   Int                  @default(0)
  contentType    String
  deliverables   String
  deadline       DateTime
  location       String?
  budgetMin      Float
  budgetMax      Float
  paymentType    String
  status         CampaignStatus       @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  isFeatured     Boolean              @default(false)
  creatorsNeeded Int                  @default(1)
  campaignType   CampaignType         @default(PAID_CAMPAIGN)
  capacity       Int?
  eventDate      DateTime?
  venue          String?
  benefits       Json                 @default("[]")
  eventStatus    EventStatus          @default(OPEN)
  paymentStatus  PaymentStatus        @default(UNPAID)
  paidAt         DateTime?
  paymentMethod  String?
  applications   Application[]
  business       BusinessProfile      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  invitations    CampaignInvitation[]

  @@index([businessId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([campaignType, status])
  @@map("campaigns")
}

model Application {
  id              String            @id @default(cuid())
  campaignId      String
  creatorId       String
  coverLetter     String
  proposedRate    Float
  timeline        String
  socialHandles   Json              @default("{}")
  portfolioUrl    String?
  status          ApplicationStatus @default(PENDING)
  workStatus      WorkStatus        @default(NONE)
  workNote        String?
  submittedAt     DateTime?
  deliverableUrls String?
  paymentStatus   PaymentStatus     @default(UNPAID)
  paidAt          DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  campaign        Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator         CreatorProfile    @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@index([creatorId])
  @@index([creatorId, createdAt(sort: Desc)])
  @@index([campaignId, status])
  @@map("applications")
}

model Conversation {
  id             String             @id @default(cuid())
  creatorId      String
  businessId     String
  campaignId     String?
  createdAt      DateTime           @default(now())
  status         ConversationStatus @default(PENDING)
  requestMessage String?
  lastMessageAt  DateTime?
  businessSeenAt DateTime?
  creatorSeenAt  DateTime?
  business       BusinessProfile    @relation("BusinessConversations", fields: [businessId], references: [id], onDelete: Cascade)
  campaign       Campaign?          @relation(fields: [campaignId], references: [id])
  creator        CreatorProfile     @relation("CreatorConversations", fields: [creatorId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([creatorId, businessId])
  @@index([businessId])
  @@index([lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

model LegalSection {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  icon      String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("legal_sections")
}

model FaqArticle {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_articles")
}

model SupportRequest {
  id        String   @id @default(cuid())
  userId    String?
  topic     String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])

  @@map("support_requests")
}

model IssueReport {
  id          String   @id @default(cuid())
  userId      String?
  type        String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])

  @@map("issue_reports")
}

model HelpArticle {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("help_articles")
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("otp_verifications")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  refId     String?
  refType   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@map("notifications")
}

model FavoriteBusiness {
  id         String          @id @default(cuid())
  creatorId  String
  businessId String
  createdAt  DateTime        @default(now())
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, businessId])
  @@map("favorite_businesses")
}

model SavedCreator {
  id         String          @id @default(cuid())
  businessId String
  creatorId  String
  createdAt  DateTime        @default(now())
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([businessId, creatorId])
  @@map("saved_creators")
}

model CampaignInvitation {
  id         String          @id @default(cuid())
  campaignId String
  creatorId  String
  businessId String
  message    String?
  createdAt  DateTime        @default(now())
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  business   BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@map("campaign_invitations")
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

enum Role {
  CREATOR
  BUSINESS
  ADMIN
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum ConversationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CampaignType {
  PAID_CAMPAIGN
  OPEN_EVENT
}

enum EventStatus {
  OPEN
  FULL
  CLOSED
}

enum WorkStatus {
  NONE
  IN_PROGRESS
  SUBMITTED
  APPROVED
}

enum PaymentStatus {
  UNPAID
  PAID
  RELEASED
}
