// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  BUSINESS
  ADMIN
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum ConversationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  phone           String   @unique
  password        String
  role            Role
  isEmailVerified Boolean  @default(false)
  isOnboarded     Boolean  @default(false)
  isActive        Boolean  @default(true)
  refreshToken    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creatorProfile   CreatorProfile?
  businessProfile  BusinessProfile?
  sentMessages     Message[]         @relation("MessageSender")
  otpVerifications OtpVerification[]
  supportRequests  SupportRequest[]
  issueReports     IssueReport[]
  notifications    Notification[]

  @@map("users")
}

model CreatorProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  username       String?  @unique
  fullName       String
  bio            String?
  location       String?
  locationLat    Float?
  locationLng    Float?
  avatarUrl      String?
  categories     String[]
  socialLinks    Json     @default("{}")
  portfolioLinks Json     @default("[]")
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  paymentMethods String[] @default([])
  prefPlatforms  String[] @default([])
  prefLocations  String[] @default([])
  prefBudgetMin  Float    @default(0)
  prefBudgetMax  Float    @default(500)

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications       Application[]
  conversations      Conversation[]     @relation("CreatorConversations")
  socialAccounts     SocialAccount[]
  favoriteBusinesses FavoriteBusiness[]

  @@map("creator_profiles")
}

model SocialAccount {
  id               String   @id @default(cuid())
  creatorProfileId String
  platform         String
  profileUrl       String
  followers        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, platform])
  @@map("social_accounts")
}

model BusinessProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  businessName        String
  description         String?
  logoUrl             String?
  website             String?
  categories          String[]
  panNo               String?
  isVerified          Boolean  @default(false)
  showPublicProfile   Boolean  @default(true)
  hideContactDetails  Boolean  @default(false)
  allowDirectMessages Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns     Campaign[]
  conversations Conversation[]     @relation("BusinessConversations")
  favoritedBy   FavoriteBusiness[]

  @@map("business_profiles")
}

model Campaign {
  id             String         @id @default(cuid())
  businessId     String
  title          String
  description    String
  category       String
  platform       String
  minFollowers   Int            @default(0)
  contentType    String
  deliverables   String
  deadline       DateTime
  location       String?
  budgetMin      Float
  budgetMax      Float
  paymentType    String
  creatorsNeeded Int            @default(1)
  status         CampaignStatus @default(ACTIVE)
  isFeatured     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  business      BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  applications  Application[]
  conversations Conversation[]

  @@map("campaigns")
}

model Application {
  id            String            @id @default(cuid())
  campaignId    String
  creatorId     String
  coverLetter   String
  proposedRate  Float
  timeline      String
  socialHandles Json              @default("{}")
  portfolioUrl  String?
  status        ApplicationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@map("applications")
}

model Conversation {
  id             String             @id @default(cuid())
  creatorId      String
  businessId     String
  campaignId     String?
  status         ConversationStatus @default(PENDING)
  requestMessage String?
  lastMessageAt  DateTime?
  businessSeenAt DateTime?
  creatorSeenAt  DateTime?
  createdAt      DateTime           @default(now())

  creator  CreatorProfile  @relation("CreatorConversations", fields: [creatorId], references: [id], onDelete: Cascade)
  business BusinessProfile @relation("BusinessConversations", fields: [businessId], references: [id], onDelete: Cascade)
  campaign Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([creatorId, businessId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model LegalSection {
  id        String   @id @default(cuid())
  type      String // PRIVACY_POLICY | TERMS | GUIDELINES
  title     String
  body      String
  icon      String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("legal_sections")
}

model FaqArticle {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_articles")
}

model SupportRequest {
  id        String   @id @default(cuid())
  userId    String?
  topic     String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("support_requests")
}

model IssueReport {
  id          String   @id @default(cuid())
  userId      String?
  type        String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("issue_reports")
}

model HelpArticle {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("help_articles")
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  refId     String?
  refType   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model FavoriteBusiness {
  id         String   @id @default(cuid())
  creatorId  String
  businessId String
  createdAt  DateTime @default(now())

  creator  CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([creatorId, businessId])
  @@map("favorite_businesses")
}
