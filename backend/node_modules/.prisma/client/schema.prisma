// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  BUSINESS
  ADMIN
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  phone           String   @unique
  password        String
  role            Role
  isEmailVerified Boolean  @default(false)
  isOnboarded     Boolean  @default(false)
  refreshToken    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creatorProfile   CreatorProfile?
  businessProfile  BusinessProfile?
  sentMessages     Message[]         @relation("MessageSender")
  otpVerifications OtpVerification[]

  @@map("users")
}

model CreatorProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  username       String?  @unique
  fullName       String
  bio            String?
  location       String?
  avatarUrl      String?
  categories     String[]
  socialLinks    Json     @default("{}")
  portfolioLinks Json     @default("[]")
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications  Application[]
  conversations Conversation[] @relation("CreatorConversations")

  @@map("creator_profiles")
}

model BusinessProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  description  String?
  logoUrl      String?
  website      String?
  categories   String[]
  panNo        String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns     Campaign[]
  conversations Conversation[] @relation("BusinessConversations")

  @@map("business_profiles")
}

model Campaign {
  id           String         @id @default(cuid())
  businessId   String
  title        String
  description  String
  category     String
  platform     String
  minFollowers Int            @default(0)
  contentType  String
  deliverables String
  deadline     DateTime
  location     String?
  budgetMin    Float
  budgetMax    Float
  paymentType  String
  status       CampaignStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  business      BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  applications  Application[]
  conversations Conversation[]

  @@map("campaigns")
}

model Application {
  id            String            @id @default(cuid())
  campaignId    String
  creatorId     String
  coverLetter   String
  proposedRate  Float
  timeline      String
  socialHandles Json              @default("{}")
  portfolioUrl  String?
  status        ApplicationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@map("applications")
}

model Conversation {
  id         String   @id @default(cuid())
  creatorId  String
  businessId String
  campaignId String?
  createdAt  DateTime @default(now())

  creator  CreatorProfile  @relation("CreatorConversations", fields: [creatorId], references: [id], onDelete: Cascade)
  business BusinessProfile @relation("BusinessConversations", fields: [businessId], references: [id], onDelete: Cascade)
  campaign Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([creatorId, businessId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}
