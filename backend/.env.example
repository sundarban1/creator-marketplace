# For production on Render, see render.yaml at the repo root — it provisions
# the Postgres database and web service, and wires most of these automatically.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creatormarket
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
FRONTEND_URL=http://localhost:5173,http://localhost:3000
# Optional: fatal | error | warn | info | debug | trace (defaults to debug in dev, info in production)
LOG_LEVEL=
# Required for the AI campaign generator (POST /api/campaigns/ai/generate). Get one at console.anthropic.com
ANTHROPIC_API_KEY=
# Sparrow SMS (Nepal) — optional. Until both are set, sendSms() logs instead of sending.
SPARROW_SMS_TOKEN=
SPARROW_SMS_FROM=
