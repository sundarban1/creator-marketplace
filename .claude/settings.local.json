{
  "permissions": {
    "allow": [
      "Bash(grep -E \"package\\\\.json$\")",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); deps={**d.get\\('dependencies',{}\\)}; print\\('\\\\n'.join\\(f'{k}: {v}' for k,v in deps.items\\(\\) if 'expo' in k.lower\\(\\)\\)\\)\")",
      "Bash(pkill -f \"expo start\")",
      "Bash(pkill -f \"metro\")",
      "Bash(pkill -f \"expo\\\\|metro\")",
      "Bash(echo \"Started with PID $!\")",
      "Bash(lsof -ti:3000)",
      "Bash(ps -p 4485 -o pid,command)",
      "Bash(curl -s http://localhost:3000/api/campaigns/platforms)",
      "Bash(npm run dev > /tmp/backend.log 2>&1 & *)",
      "Bash(echo \"Mobile PID: $!\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8081)",
      "Bash(xcrun simctl *)"
