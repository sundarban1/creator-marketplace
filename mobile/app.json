{
  "expo": {
    "name": "kolab",
    "slug": "kolab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "kolab",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.sundarban.kolab",
      "config": {
        "googleMapsApiKey": "AIzaSyAJrdBTZyJH0Sxku7uG-_V4x5lSv4xWii0"
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "fb1241262111343589"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.543768819635-fuslrtr8mt6bmi2jslc3h3hcqg4drhdk"
            ]
          }
        ],
        "FacebookAppID": "1241262111343589",
        "FacebookDisplayName": "kolab"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAJrdBTZyJH0Sxku7uG-_V4x5lSv4xWii0"
        }
      },
      "package": "com.sundarban.kolab"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow kolab to access your location to find nearby campaigns."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#6d28d9"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow kolab to access your photos to update your profile picture.",
          "cameraPermission": "Allow kolab to use your camera to take a profile photo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "77b46836-b5cc-408d-abba-c6a908fa3e43"
      }
    },
    "owner": "sundarban"
  }
}
